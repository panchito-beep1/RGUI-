            callback(currentText)
        end)
    end

    return box
end

function TabComponent:AddGraph(title, maxPoints, options)
    local RunService = game:GetService("RunService")
    local theme      = getTheme(self)
 
    options = options or {}
    if type(options) == "userdata" and options:IsA("Color3") then
        options = { LineColor = options }
    end
 
    local lineColor   = options.LineColor   or theme.GraphLine
    local yMin        = options.YMin
    local yMax        = options.YMax
    local smoothAlpha = options.SmoothAlpha or 0.2
    local maxLines    = options.MaxLines    or 120   -- pool size; tune as needed
 
    -- ── Circular buffer ────────────────────────────────────────────────────
    local buf     = table.create(maxPoints, 0)
    local bufHead = 1   -- physical index of the oldest element
    local bufSize = 0   -- how many elements are currently stored
    local smoothed = nil
    local dirty    = false
 
    -- ── UI hierarchy ───────────────────────────────────────────────────────
    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size        = UDim2.new(1, 0, 0, 108)
    container.LayoutOrder = self:_nextOrder()
    container.Parent      = self._page
 
    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size       = UDim2.new(1, 0, 0, 18)
    titleLabel.Font       = Enum.Font.RobotoMono
    titleLabel.Text       = title
    titleLabel.TextColor3 = theme.Text
    titleLabel.TextSize   = 12
    titleLabel.Parent     = container
 
    local graphFrame = Instance.new("Frame")
    graphFrame.BackgroundColor3 = theme.GraphBg
    graphFrame.BorderSizePixel  = 0
    graphFrame.Position         = UDim2.new(0, 0, 0, 20)
    graphFrame.Size             = UDim2.new(1, 0, 0, 80)
    graphFrame.ClipsDescendants = true
    graphFrame.Parent           = container
    applyCorner(graphFrame, 2)
    applyBorder(graphFrame, theme.Border)
 
    local linesHolder = Instance.new("Frame")
    linesHolder.BackgroundTransparency = 1
    linesHolder.Size   = UDim2.new(1, 0, 1, 0)
    linesHolder.Parent = graphFrame
 
    -- ── Pre-allocate the pool ONCE (never create/destroy frames again) ─────
    local pool = table.create(maxLines)
    for i = 1, maxLines do
        local f = Instance.new("Frame")
        f.BackgroundColor3 = lineColor
        f.BorderSizePixel  = 0
        f.Size             = UDim2.new(0, 0, 0, 2)
        f.Visible          = false
        f.Parent           = linesHolder
        pool[i]            = f
    end
 
    -- ── Catmull-Rom spline ─────────────────────────────────────────────────
    local function cr(p0, p1, p2, p3, t)
        local t2 = t * t
        local t3 = t2 * t
        return 0.5 * (
            (2 * p1) +
            (-p0 + p2) * t +
            (2*p0 - 5*p1 + 4*p2 - p3) * t2 +
            (-p0 + 3*p1 - 3*p2 + p3) * t3
        )
    end
 
    -- ── Redraw (only called by the Heartbeat; never called in Push) ────────
    local function redraw()
        local W = graphFrame.AbsoluteSize.X
        local H = graphFrame.AbsoluteSize.Y
        if W <= 0 or H <= 0 or bufSize < 2 then
            for i = 1, maxLines do pool[i].Visible = false end
            return
        end
 
        -- Y-axis range
        local lo, hi
        if yMin and yMax then
            lo, hi = yMin, yMax
        else
            lo, hi = math.huge, -math.huge
            for i = 1, bufSize do
                local v = buf[((bufHead - 1 + i - 1) % maxPoints) + 1]
                if v < lo then lo = v end
                if v > hi then hi = v end
            end
            if lo == hi then hi = lo + 1 end
        end
        local range = hi - lo
 
        -- Convert samples to pixel coords (plain tables; no Vector2 overhead)
        local PAD  = 3                -- px gap from top/bottom edge
        local drawH = H - PAD * 2
        local px = table.create(bufSize)
        local py = table.create(bufSize)
        for i = 1, bufSize do
            local v = buf[((bufHead - 1 + i - 1) % maxPoints) + 1]
            px[i] = (i - 1) / (bufSize - 1) * W
            py[i] = PAD + drawH - ((v - lo) / range) * drawH
        end
 
        -- Budget Catmull-Rom steps across pool
        local intervals  = bufSize - 1
        local stepsEach  = math.max(1, math.floor(maxLines / intervals))
        local used = 0
 
        for i = 1, intervals do
            local i0 = math.max(1, i - 1)
            local i2 = math.min(bufSize, i + 1)
            local i3 = math.min(bufSize, i + 2)
            local lx, ly = px[i], py[i]
 
            for s = 1, stepsEach do
                local t  = s / stepsEach
                local nx = cr(px[i0], px[i], px[i2], px[i3], t)
                local ny = cr(py[i0], py[i], py[i2], py[i3], t)
                local dx = nx - lx
                local dy = ny - ly
                local len = math.sqrt(dx * dx + dy * dy)
                if len > 0.5 and used < maxLines then
                    used = used + 1
                    local f = pool[used]
                    f.Size     = UDim2.new(0, len + 1, 0, 2)
                    f.Position = UDim2.new(0, lx, 0, ly - 1)
                    f.Rotation = math.deg(math.atan2(dy, dx))
                    f.Visible  = true
                end
                lx, ly = nx, ny
            end
        end
 
        -- Hide leftover pool frames from a previous (larger) draw
        for i = used + 1, maxLines do
            pool[i].Visible = false
        end
    end
 
    -- ── Heartbeat connection: rate-limits redraws to one per game frame ────
    local hbConn = RunService.Heartbeat:Connect(function()
        if dirty then
            dirty = false
            redraw()
        end
    end)
 
    -- Resize triggers a re-layout on the next frame
    graphFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
        dirty = true
    end)
 
    -- ── Public API ─────────────────────────────────────────────────────────
    local graphObj = {}
 
    -- Push a new sample value.  Call as fast as you like – one redraw/frame.
    function graphObj:Push(rawValue)
        -- Exponential moving-average smoothing
        if smoothed == nil then
            smoothed = rawValue
        else
            smoothed = smoothed + (rawValue - smoothed) * smoothAlpha
        end
 
        -- Write into circular buffer (O(1); no table.remove shift)
        local tail = ((bufHead - 1 + bufSize) % maxPoints) + 1
        buf[tail] = smoothed
        if bufSize < maxPoints then
            bufSize = bufSize + 1
        else
            -- Buffer full: advance head (drop oldest element)
            bufHead = (bufHead % maxPoints) + 1
        end
 
        dirty = true   -- schedule a redraw on the next Heartbeat
    end
 
    -- Change the line colour at runtime.
    function graphObj:SetColor(color)
        lineColor = color
        for i = 1, maxLines do
            pool[i].BackgroundColor3 = color
        end
    end
 
    -- Clean up when the graph is no longer needed.
    function graphObj:Destroy()
        hbConn:Disconnect()
        container:Destroy()
    end
 
    return graphObj
end

-- ── Window:CreateWatermark(text, options) ───────────────────────────────────
function RGui:CreateWatermark(text, options)
    local theme = self._theme
    options = options or {}

    local wmGui = Instance.new("ScreenGui")
    wmGui.Name = "RGui_Watermark"
    wmGui.ResetOnSpawn = false
    wmGui.Parent = CoreGui

    local wmFrame = Instance.new("Frame")
    wmFrame.BackgroundColor3 = options.BackgroundColor or theme.TitleBg
    wmFrame.BackgroundTransparency = options.BackgroundTransparency or 0.4
    wmFrame.Position = options.Position or UDim2.new(0, 10, 0, 10)
    wmFrame.Size = UDim2.new(0, 0, 0, 0)
    wmFrame.Parent = wmGui
    applyCorner(wmFrame, 2)
    applyBorder(wmFrame, theme.Border)

    local icon
    if options.Icon then
        icon = Instance.new("ImageLabel")
        icon.BackgroundTransparency = 1
        icon.Size = UDim2.new(0, 20, 0, 20)
        icon.Position = UDim2.new(0, 4, 0.5, -10)
        icon.Image = options.Icon
        icon.Parent = wmFrame
    end

    local wmLabel = Instance.new("TextLabel")
    wmLabel.BackgroundTransparency = 1
    wmLabel.Font = Enum.Font.RobotoMono
    wmLabel.Text = text
    wmLabel.TextColor3 = options.TextColor or theme.Text
    wmLabel.TextSize = options.TextSize or 13
    wmLabel.TextXAlignment = Enum.TextXAlignment.Left
    wmLabel.RichText = true
    wmLabel.Parent = wmFrame

    if icon then
        wmLabel.Position = UDim2.new(0, 28, 0, 0)
        wmLabel.Size = UDim2.new(1, -32, 1, 0)
    else
        wmLabel.Position = UDim2.new(0, 8, 0, 0)
        wmLabel.Size = UDim2.new(1, -16, 1, 0)
    end

    local function updateSize()
        local textBounds = TextService:GetTextSize(wmLabel.Text, wmLabel.TextSize, wmLabel.Font, Vector2.new(math.huge, math.huge))
        wmFrame.Size = UDim2.new(0, textBounds.X + 16 + (icon and 24 or 0), 0, math.max(textBounds.Y + 8, 24))
    end
    updateSize()

    makeDraggable(wmFrame, wmFrame)

    local wmObj = {}
    function wmObj:Destroy()
        wmGui:Destroy()
    end
    function wmObj:Update(newText, newOptions)
        if newText ~= nil then wmLabel.Text = newText end
        if newOptions then
            if newOptions.Icon ~= nil then
                if newOptions.Icon == "" or newOptions.Icon == false then
                    if icon then icon:Destroy(); icon = nil; wmLabel.Position = UDim2.new(0, 8, 0, 0); wmLabel.Size = UDim2.new(1, -16, 1, 0) end
                else
                    if not icon then
                        icon = Instance.new("ImageLabel"); icon.BackgroundTransparency = 1; icon.Size = UDim2.new(0, 20, 0, 20); icon.Position = UDim2.new(0, 4, 0.5, -10); icon.Parent = wmFrame
                        wmLabel.Position = UDim2.new(0, 28, 0, 0); wmLabel.Size = UDim2.new(1, -32, 1, 0)
                    end
                    icon.Image = newOptions.Icon
                end
            end
            if newOptions.TextColor then wmLabel.TextColor3 = newOptions.TextColor end
            if newOptions.TextSize then wmLabel.TextSize = newOptions.TextSize end
            if newOptions.BackgroundColor then wmFrame.BackgroundColor3 = newOptions.BackgroundColor end
            if newOptions.BackgroundTransparency then wmFrame.BackgroundTransparency = newOptions.BackgroundTransparency end
            if newOptions.Position then wmFrame.Position = newOptions.Position end
            if newOptions.Font then wmLabel.Font = newOptions.Font end
        end
        updateSize()
    end
    self._watermark = wmObj
    return wmObj
end

-- ── Window:CreateKeySystem(config) ────────────────────────────────────────────
function RGui:CreateKeySystem(config)
    local theme = self._theme
    local services = config.Services or {}
    local description = config.Description or "Enter your key to continue."
    local title = config.Title or "Key System"
    local onSuccess = config.Callback or function() end

    local serviceNames = {}
    for name, data in pairs(services) do
        table.insert(serviceNames, name)
