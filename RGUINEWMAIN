local TWEEN_FAST = TweenInfo.new(0.1, Enum.EasingStyle.Quad)

-- ── Internal Helpers ──────────────────────────────────────────────────────────
local function applyCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 2)
    c.Parent = parent
    return c
end

local function applyBorder(parent, color)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function applyPadding(parent, px)
    local p = Instance.new("UIPadding")
    p.PaddingLeft   = UDim.new(0, px)
    p.PaddingRight  = UDim.new(0, px)
    p.PaddingTop    = UDim.new(0, px)
    p.PaddingBottom = UDim.new(0, px)
    p.Parent = parent
    return p
end

local function makeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging, dragStart, startPos = true, input.Position, frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- ── Risky colour warning helper ──────────────────────────────────────────────
local function warnCustomColor(tab, componentName)
    if tab._window then
        tab._window:Notify("Theme Warning",
            "Custom colour used on " .. componentName .. " – this may break theme consistency!",
            4, { Color = Color3.fromRGB(255, 100, 100) })
    end
end

-- ── RGui.new(title, customTheme, options) ────────────────────────────────────
function RGui.new(title, customTheme, options)
    local self = setmetatable({}, RGui)
    title = title or "R-GUI"
    options = options or {}

    local theme = {}
    for k, v in pairs(RGui.DefaultTheme) do theme[k] = v end
    if customTheme then
        for k, v in pairs(customTheme) do theme[k] = v end
    end
    self._theme = theme

    local screen = Instance.new("ScreenGui")
    screen.Name = "RGui_" .. title
    screen.ResetOnSpawn = false
    screen.Parent = CoreGui

    local mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.BackgroundTransparency = 1
    mainFrame.Position = UDim2.new(0.5, -200, 0.3, 0)
    mainFrame.Size = UDim2.new(0, 400, 0, 300)
    mainFrame.Parent = screen
    mainFrame.Position = options.Position or UDim2.new(0.5, -200, 0.3, 0)
    mainFrame.Size     = options.Size     or UDim2.new(0, 400, 0, 300)

    -- Titlebar
    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.BackgroundColor3 = theme.TitleBg
    titleBar.Size = UDim2.new(1, 0, 0, 24)
    titleBar.Parent = mainFrame
    applyCorner(titleBar, 2)
    applyBorder(titleBar, theme.Border)

    local titleLbl = Instance.new("TextLabel")
    titleLbl.BackgroundTransparency = 1
    titleLbl.Font = Enum.Font.RobotoMono
    titleLbl.Text = title
    titleLbl.TextColor3 = theme.Text
    titleLbl.TextSize = 13
    titleLbl.TextXAlignment = Enum.TextXAlignment.Left
    titleLbl.Parent = titleBar

    -- Icon support for window
    if options.Icon then
        local icon = Instance.new("ImageLabel")
        icon.BackgroundTransparency = 1
        icon.Size = UDim2.new(0, 20, 0, 20)
        icon.Position = UDim2.new(0, 4, 0.5, -10)
        icon.Image = options.Icon
        icon.Parent = titleBar
        titleLbl.Position = UDim2.new(0, 28, 0, 0)
        titleLbl.Size = UDim2.new(1, -88, 1, 0)
    else
        titleLbl.Position = UDim2.new(0, 8, 0, 0)
        titleLbl.Size = UDim2.new(1, -60, 1, 0)
    end

    local collapseBtn = Instance.new("TextButton")
    collapseBtn.BackgroundTransparency = 1
    collapseBtn.Position = UDim2.new(1, -44, 0, 0)
    collapseBtn.Size = UDim2.new(0, 20, 1, 0)
    collapseBtn.Font = Enum.Font.RobotoMono
    collapseBtn.Text = "-"
    collapseBtn.TextColor3 = theme.SubText
    collapseBtn.TextSize = 14
    collapseBtn.Parent = titleBar

    local closeBtn = Instance.new("TextButton")
    closeBtn.BackgroundTransparency = 1
    closeBtn.Position = UDim2.new(1, -20, 0, 0)
    closeBtn.Size = UDim2.new(0, 20, 1, 0)
    closeBtn.Font = Enum.Font.RobotoMono
    closeBtn.Text = "×"
    closeBtn.TextColor3 = theme.SubText
    closeBtn.TextSize = 16
    closeBtn.Parent = titleBar

    -- Body
    local body = Instance.new("Frame")
    body.Name = "Body"
    body.BackgroundColor3 = theme.WindowBg
    body.Position = UDim2.new(0, 0, 0, 23)
    body.Size = UDim2.new(1, 0, 1, -23)
    body.ClipsDescendants = true
    body.Parent = mainFrame
    applyCorner(body, 2)
    applyBorder(body, theme.Border)

    local isCollapsed = false
    collapseBtn.MouseButton1Click:Connect(function()
        isCollapsed = not isCollapsed
        body.Visible = not isCollapsed
        collapseBtn.Text = isCollapsed and "+" or "-"
    end)
    closeBtn.MouseButton1Click:Connect(function()
        screen:Destroy()
    end)

    -- Tab container
    local tabContainer = Instance.new("Frame")
    tabContainer.BackgroundColor3 = theme.TabBarBg
    tabContainer.Size = UDim2.new(1, 0, 0, 26)
    tabContainer.Parent = body
    applyBorder(tabContainer, theme.Border)

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Parent = tabContainer

    -- Page container
    local pageContainer = Instance.new("Frame")
    pageContainer.BackgroundTransparency = 1
    pageContainer.Position = UDim2.new(0, 0, 0, 26)
    pageContainer.Size = UDim2.new(1, 0, 1, -26)
    pageContainer.Parent = body

    -- Resizer
    local resizer = Instance.new("TextButton")
    resizer.BackgroundTransparency = 1
    resizer.Size = UDim2.new(0, 12, 0, 12)
    resizer.Position = UDim2.new(1, -12, 1, -12)
    resizer.Text = "◢"
    resizer.TextColor3 = theme.SubText
    resizer.TextSize = 10
    resizer.ZIndex = 10
    resizer.Parent = body

    local resizing, resizeStart, startSize = false
    resizer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing, resizeStart, startSize = true, input.Position, mainFrame.Size
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - resizeStart
            mainFrame.Size = UDim2.new(
                0, math.clamp(startSize.X.Offset + delta.X, 250, 800),
                0, math.clamp(startSize.Y.Offset + delta.Y, 150, 800)
            )
        end
    end)

    makeDraggable(mainFrame, titleBar)

    self._screen = screen
    self._mainFrame = mainFrame
    self._tabContainer = tabContainer
    self._pageContainer = pageContainer
    self._tabs = {}
    self._watermark = nil
    self._notificationGui = nil

    return self
end

-- ── Window:AddTab(name, iconOrOptions) ────────────────────────────────────────
function RGui:AddTab(name, iconOrOptions)
    local theme = self._theme
    local options = {}
    if type(iconOrOptions) == "string" then
        options = {Icon = iconOrOptions}
    elseif type(iconOrOptions) == "table" then
        options = iconOrOptions
    end

    local tabBtn = Instance.new("TextButton")
    tabBtn.BackgroundColor3 = theme.TabNormal
    tabBtn.Size = UDim2.new(0, 0, 1, 0)
    tabBtn.Font = Enum.Font.RobotoMono
    tabBtn.Text = ""
    tabBtn.TextColor3 = theme.TabNormalText
    tabBtn.TextSize = 13
    tabBtn.Parent = self._tabContainer
    applyBorder(tabBtn, theme.Border)

    local tabText = Instance.new("TextLabel")
    tabText.BackgroundTransparency = 1
    tabText.Font = Enum.Font.RobotoMono
    tabText.Text = name
    tabText.TextColor3 = theme.TabNormalText
    tabText.TextSize = 13
    tabText.Parent = tabBtn

    local icon
    if options.Icon then
        icon = Instance.new("ImageLabel")
        icon.BackgroundTransparency = 1
        icon.Size = UDim2.new(0, 18, 0, 18)
        icon.Position = UDim2.new(0, 4, 0.5, -9)
        icon.Image = options.Icon
        icon.Parent = tabBtn
    end

    local txtSize = TextService:GetTextSize(name, 13, Enum.Font.RobotoMono, Vector2.new(999, 26))
    local totalWidth = txtSize.X + 16 + (icon and 24 or 0)
    tabBtn.Size = UDim2.new(0, totalWidth, 1, 0)

    if icon then
        tabText.Position = UDim2.new(0, 26, 0, 0)
        tabText.Size = UDim2.new(1, -26, 1, 0)
    else
        tabText.Position = UDim2.new(0, 8, 0, 0)
        tabText.Size = UDim2.new(1, -16, 1, 0)
    end

    local page = Instance.new("ScrollingFrame")
    page.BackgroundTransparency = 1
    page.Size = UDim2.new(1, 0, 1, 0)
    page.ScrollBarThickness = 4
    page.ScrollBarImageColor3 = theme.Accent
    page.Visible = false
    page.Parent = self._pageContainer
    applyPadding(page, 8)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = page

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 16)
    end)

    table.insert(self._tabs, {Button = tabBtn, Page = page, TextLabel = tabText})

    tabBtn.MouseButton1Click:Connect(function()
        for _, t in ipairs(self._tabs) do
            t.Page.Visible = false
            t.Button.BackgroundColor3 = theme.TabNormal
            t.TextLabel.TextColor3 = theme.TabNormalText
        end
        page.Visible = true
        tabBtn.BackgroundColor3 = theme.TabActive
        tabText.TextColor3 = theme.TabActiveText
    end)

    if #self._tabs == 1 then
        page.Visible = true
        tabBtn.BackgroundColor3 = theme.TabActive
        tabText.TextColor3 = theme.TabActiveText
    end

    local tabObj = setmetatable({}, TabComponent)
    tabObj._page = page
    tabObj._layoutOrder = 0
    tabObj._window = self
    return tabObj
end

-- ── Tab helper ────────────────────────────────────────────────────────────────
function TabComponent:_nextOrder()
    self._layoutOrder = self._layoutOrder + 1
    return self._layoutOrder
end

local function getTheme(tab)
    return tab._window._theme
end

-- ── Tab:AddButton(text, callback, iconOrOptions) ─────────────────────────────
function TabComponent:AddButton(text, callback, iconOrOptions)
    local theme = getTheme(self)
    local options = {}
    if type(iconOrOptions) == "string" then
        options = {Icon = iconOrOptions}
    elseif type(iconOrOptions) == "table" then
        options = iconOrOptions
    end

    local bgColor = theme.FrameBg
    if options.Color then
        warnCustomColor(self, "Button")
        bgColor = options.Color
    end

    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = bgColor
    btn.Size = UDim2.new(1, 0, 0, 24)
    btn.LayoutOrder = self:_nextOrder()
    btn.Font = Enum.Font.RobotoMono
    btn.Text = ""
    btn.TextColor3 = theme.Text
    btn.TextSize = 13
    btn.Parent = self._page
    applyCorner(btn, 2)
    applyBorder(btn, theme.Border)

    local icon
    if options.Icon then
        icon = Instance.new("ImageLabel")
        icon.BackgroundTransparency = 1
        icon.Size = UDim2.new(0, 18, 0, 18)
        icon.Position = UDim2.new(0, 4, 0.5, -9)
        icon.Image = options.Icon
        icon.Parent = btn
    end

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Position = icon and UDim2.new(0, 26, 0, 0) or UDim2.new(0, 4, 0, 0)
    lbl.Size = UDim2.new(1, (icon and -30 or -8), 1, 0)
    lbl.Font = Enum.Font.RobotoMono
    lbl.Text = text
    lbl.TextColor3 = theme.Text
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn

    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = options.Color or theme.FrameBgHover end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = bgColor end)

    if callback then
        btn.MouseButton1Click:Connect(function()
            TweenService:Create(btn, TWEEN_FAST, {BackgroundColor3 = theme.Accent}):Play()
            task.delay(0.1, function()
                TweenService:Create(btn, TWEEN_FAST, {BackgroundColor3 = options.Color or theme.FrameBgHover}):Play()
            end)
            callback()
        end)
    end
    return btn
end

-- ── Tab:AddCheckbox(text, default, callback, optOptions) ─────────────────────
function TabComponent:AddCheckbox(text, default, callback, optOptions)
    local theme = getTheme(self)
    local options = optOptions or {}
    local checked = default or false

    local bgColor = theme.FrameBg
    if options.Color then
        warnCustomColor(self, "Checkbox")
        bgColor = options.Color
    end

    local row = Instance.new("TextButton")
    row.BackgroundColor3 = bgColor
    row.Size = UDim2.new(1, 0, 0, 24)
    row.LayoutOrder = self:_nextOrder()
    row.Text = ""
    row.Parent = self._page
    applyCorner(row, 2)
    applyBorder(row, theme.Border)

    row.MouseEnter:Connect(function() row.BackgroundColor3 = options.Color or theme.FrameBgHover end)
    row.MouseLeave:Connect(function() row.BackgroundColor3 = bgColor end)

    local check = Instance.new("TextLabel")
    check.BackgroundColor3 = checked and theme.CheckOn or theme.CheckOff
    check.Position = UDim2.new(0, 4, 0.5, -8)
    check.Size = UDim2.new(0, 16, 0, 16)
    check.Text = checked and "✓" or ""
    check.TextColor3 = theme.Text
    check.Font = Enum.Font.RobotoMono
    check.TextSize = 12
    check.Parent = row
    applyCorner(check, 2)
    applyBorder(check, theme.Accent)

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 24, 0, 0)
    lbl.Size = UDim2.new(1, -24, 1, 0)
    lbl.Font = Enum.Font.RobotoMono
    lbl.Text = text
    lbl.TextColor3 = theme.Text
    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = row

    row.MouseButton1Click:Connect(function()
        checked = not checked
        check.Text = checked and "✓" or ""
        TweenService:Create(check, TWEEN_FAST, {
            BackgroundColor3 = checked and theme.CheckOn or theme.CheckOff
        }):Play()
        if callback then callback(checked) end
    end)
end

-- ── Tab:AddSlider(text, min, max, default, callback, optOptions) ─────────────
function TabComponent:AddSlider(text, min, max, default, callback, optOptions)
    local theme = getTheme(self)
    local options = optOptions or {}
    min = min or 0
    max = max or 100
    default = math.clamp(default or min, min, max)
    local value = default

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 24)
    container.LayoutOrder = self:_nextOrder()
    container.Parent = self._page

    local track = Instance.new("TextButton")
    track.BackgroundColor3 = options.Color or theme.SliderTrack
    if options.Color then warnCustomColor(self, "Slider") end
    track.Size = UDim2.new(1, 0, 1, 0)
    track.Text = ""
    track.Parent = container
    applyCorner(track, 2)
    applyBorder(track, theme.Border)

    local fill = Instance.new("Frame")
    fill.BackgroundColor3 = theme.SliderFill
    fill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
    fill.Parent = track
    applyCorner(fill, 2)

    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.Font = Enum.Font.RobotoMono
    lbl.Text = string.format("%s: %d", text, value)
    lbl.TextColor3 = theme.Text
    lbl.TextSize = 13
    lbl.ZIndex = 2
    lbl.Parent = track

    track.MouseEnter:Connect(function() track.BackgroundColor3 = theme.FrameBgHover end)
    track.MouseLeave:Connect(function() track.BackgroundColor3 = options.Color or theme.SliderTrack end)

    local function updateFromInput(input)
        local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max - min) * rel + 0.5)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        lbl.Text = string.format("%s: %d", text, value)
        if callback then callback(value) end
    end

    local dragging = false
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateFromInput(i)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromInput(i)
        end
    end)
end

-- ── Tab:AddDropdown(text, options, default, callback, optOptions) ────────────
function TabComponent:AddDropdown(text, options, default, callback, optOptions)
    local theme = getTheme(self)
    local opt = optOptions or {}
    local selected = default or options[1]
    local isOpen = false

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 24)
    container.LayoutOrder = self:_nextOrder()
    container.ClipsDescendants = true
    container.Parent = self._page

    local header = Instance.new("TextButton")
    header.BackgroundColor3 = opt.Color or theme.FrameBg
    if opt.Color then warnCustomColor(self, "Dropdown") end
    header.Size = UDim2.new(1, 0, 0, 24)
    header.Font = Enum.Font.RobotoMono
    header.Text = string.format(" %s: %s", text, tostring(selected))
    header.TextColor3 = theme.Text
    header.TextSize = 13
    header.TextXAlignment = Enum.TextXAlignment.Left
    header.Parent = container
    applyCorner(header, 2)
    applyBorder(header, theme.Border)

    local listFrame = Instance.new("Frame")
    listFrame.BackgroundColor3 = theme.TabNormal
    listFrame.Position = UDim2.new(0, 0, 0, 26)
    listFrame.Size = UDim2.new(1, 0, 0, 0)
    listFrame.ClipsDescendants = true
    listFrame.Parent = container
    applyBorder(listFrame, theme.Border)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = listFrame

    header.MouseButton1Click:Connect(function()
        isOpen = not isOpen
        local targetHeight = isOpen and (26 + (#options * 22)) or 24
        TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, targetHeight)}):Play()
        TweenService:Create(listFrame, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, #options * 22)}):Play()
    end)

    for i, optItem in ipairs(options) do
        local optBtn = Instance.new("TextButton")
        optBtn.BackgroundTransparency = 1
        optBtn.Size = UDim2.new(1, 0, 0, 22)
        optBtn.Font = Enum.Font.RobotoMono
        optBtn.Text = " " .. tostring(optItem)
        optBtn.TextColor3 = theme.TabNormalText
        optBtn.TextSize = 12
        optBtn.TextXAlignment = Enum.TextXAlignment.Left
        optBtn.LayoutOrder = i
        optBtn.Parent = listFrame

        optBtn.MouseEnter:Connect(function() optBtn.TextColor3 = theme.Accent end)
        optBtn.MouseLeave:Connect(function() optBtn.TextColor3 = theme.TabNormalText end)

        optBtn.MouseButton1Click:Connect(function()
            selected = optItem
            header.Text = string.format(" %s: %s", text, tostring(selected))
            isOpen = false
