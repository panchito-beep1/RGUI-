    else
        titleLbl.Position = UDim2.new(0, 8, 0, 0)
        titleLbl.Size = UDim2.new(1, -28, 1, 0)
    end

    local closeBtn = Instance.new("TextButton")
    closeBtn.BackgroundTransparency = 1
    closeBtn.Position = UDim2.new(1, -20, 0, 0)
    closeBtn.Size = UDim2.new(0, 20, 1, 0)
    closeBtn.Font = Enum.Font.RobotoMono
    closeBtn.Text = "×"
    closeBtn.TextColor3 = theme.SubText
    closeBtn.TextSize = 14
    closeBtn.Parent = titleBar
    closeBtn.MouseButton1Click:Connect(function() keyScreen:Destroy() end)

    makeDraggable(mainFrame, titleBar)

    -- Left column
    local leftPanel = Instance.new("Frame")
    leftPanel.BackgroundTransparency = 1
    leftPanel.Position = UDim2.new(0, 8, 0, 30)
    leftPanel.Size = UDim2.new(0, 180, 1, -38)
    leftPanel.ClipsDescendants = false
    leftPanel.Parent = mainFrame

    local scriptTitle = Instance.new("TextLabel")
    scriptTitle.BackgroundTransparency = 1
    scriptTitle.Size = UDim2.new(1, 0, 0, 18)
    scriptTitle.Font = Enum.Font.RobotoMono
    scriptTitle.Text = config.ScriptTitle or "My Script"
    scriptTitle.TextColor3 = theme.Accent
    scriptTitle.TextSize = 13
    scriptTitle.TextXAlignment = Enum.TextXAlignment.Left
    scriptTitle.Parent = leftPanel

    -- Key input + copy button row
    local inputRow = Instance.new("Frame")
    inputRow.BackgroundTransparency = 1
    inputRow.Position = UDim2.new(0, 0, 0, 26)
    inputRow.Size = UDim2.new(1, 0, 0, 24)
    inputRow.Parent = leftPanel

    local keyInput = Instance.new("TextBox")
    keyInput.BackgroundColor3 = theme.FrameBg
    keyInput.Size = UDim2.new(1, -28, 1, 0)
    keyInput.Font = Enum.Font.RobotoMono
    keyInput.PlaceholderText = "Enter key..."
    keyInput.PlaceholderColor3 = theme.SubText
    keyInput.Text = ""
    keyInput.TextColor3 = theme.Text
    keyInput.TextSize = 13
    keyInput.Parent = inputRow
    applyCorner(keyInput, 2)
    applyBorder(keyInput, theme.Border)

    local copyBtn = Instance.new("TextButton")
    copyBtn.BackgroundColor3 = theme.FrameBg
    copyBtn.Size = UDim2.new(0, 24, 1, 0)
    copyBtn.Position = UDim2.new(1, -24, 0, 0)
    copyBtn.Font = Enum.Font.RobotoMono
    copyBtn.Text = "📋"
    copyBtn.TextColor3 = theme.Text
    copyBtn.TextSize = 14
    copyBtn.Visible = false
    copyBtn.Parent = inputRow
    applyCorner(copyBtn, 2)
    applyBorder(copyBtn, theme.Border)

    copyBtn.MouseButton1Click:Connect(function()
        local serviceData = services[selectedService]
        local toCopy = serviceData.CopyLink or serviceData.CopyKey
        if toCopy then
            -- Use ClipboardService for reliability
            game:GetService("ClipboardService"):SetClipboard(toCopy)
            -- Visual feedback
            copyBtn.BackgroundColor3 = theme.Accent
            task.delay(0.2, function() copyBtn.BackgroundColor3 = theme.FrameBg end)
            -- Show a quick “Copied!” notification
            self:Notify("Copied!", "The key/link has been copied.", 2, {
                Color = theme.Accent
            })
        end
    end)

    -- Service dropdown
    local serviceBtn = Instance.new("TextButton")
    serviceBtn.BackgroundColor3 = theme.FrameBg
    serviceBtn.Position = UDim2.new(0, 0, 0, 60)
    serviceBtn.Size = UDim2.new(1, 0, 0, 24)
    serviceBtn.Font = Enum.Font.RobotoMono
    serviceBtn.Text = "  " .. serviceNames[1]
    serviceBtn.TextColor3 = theme.Text
    serviceBtn.TextSize = 13
    serviceBtn.TextXAlignment = Enum.TextXAlignment.Left
    serviceBtn.Parent = leftPanel
    applyCorner(serviceBtn, 2)
    applyBorder(serviceBtn, theme.Border)

    local serviceList = Instance.new("Frame")
    serviceList.BackgroundColor3 = theme.TabNormal
    serviceList.Size = UDim2.new(0, 180, 0, 0)
    serviceList.Visible = false
    serviceList.ZIndex = 10
    serviceList.Parent = mainFrame
    applyBorder(serviceList, theme.Border)

    local serviceLayout = Instance.new("UIListLayout")
    serviceLayout.SortOrder = Enum.SortOrder.LayoutOrder
    serviceLayout.Parent = serviceList

    local selectedService = serviceNames[1]
    local serviceButtons = {}
    for i, srv in ipairs(serviceNames) do
        local btn = Instance.new("TextButton")
        btn.BackgroundTransparency = 1
        btn.Size = UDim2.new(1, 0, 0, 22)
        btn.Font = Enum.Font.RobotoMono
        btn.Text = " " .. srv
        btn.TextColor3 = theme.TabNormalText
        btn.TextSize = 12
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.LayoutOrder = i
        btn.ZIndex = 10
        btn.Parent = serviceList

        btn.MouseEnter:Connect(function() btn.TextColor3 = theme.Accent end)
        btn.MouseLeave:Connect(function() btn.TextColor3 = theme.TabNormalText end)
        btn.MouseButton1Click:Connect(function()
            selectedService = srv
            serviceBtn.Text = "  " .. srv
            serviceList.Visible = false
            TweenService:Create(serviceList, TWEEN_FAST, {Size = UDim2.new(0, 180, 0, 0)}):Play()
            local data = services[srv]
            copyBtn.Visible = data and (data.CopyLink or data.CopyKey) ~= nil
            keyInput.Size = copyBtn.Visible and UDim2.new(1, -28, 1, 0) or UDim2.new(1, 0, 1, 0)
        end)
        serviceButtons[srv] = btn
    end

    local isServiceOpen = false
    serviceBtn.MouseButton1Click:Connect(function()
        isServiceOpen = not isServiceOpen
        if isServiceOpen then
            local absPos = serviceBtn.AbsolutePosition
            local absSize = serviceBtn.AbsoluteSize
            serviceList.Position = UDim2.new(0, absPos.X - mainFrame.AbsolutePosition.X,
                                             0, absPos.Y + absSize.Y - mainFrame.AbsolutePosition.Y)
            serviceList.Visible = true
            local listHeight = #serviceNames * 22
            TweenService:Create(serviceList, TWEEN_FAST, {Size = UDim2.new(0, 180, 0, listHeight)}):Play()
        else
            TweenService:Create(serviceList, TWEEN_FAST, {Size = UDim2.new(0, 180, 0, 0)}):Play()
            task.delay(0.1, function() serviceList.Visible = false end)
        end
    end)

    -- Submit button
    local submitBtn = Instance.new("TextButton")
    submitBtn.BackgroundColor3 = theme.FrameBg
    submitBtn.Position = UDim2.new(0, 0, 1, -28)
    submitBtn.Size = UDim2.new(1, 0, 0, 24)
    submitBtn.Font = Enum.Font.RobotoMono
    submitBtn.Text = "Check Key"
    submitBtn.TextColor3 = theme.Text
    submitBtn.TextSize = 13
    submitBtn.Parent = leftPanel
    applyCorner(submitBtn, 2)
    applyBorder(submitBtn, theme.Border)

    submitBtn.MouseButton1Click:Connect(function()
        local service = services[selectedService]
        if service and service.Validate then
            local key = keyInput.Text
            if service.Validate(key) then
                onSuccess(selectedService, key)
                keyScreen:Destroy()
            else
                local origColor = keyInput.BackgroundColor3
                keyInput.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
                task.delay(0.3, function()
                    keyInput.BackgroundColor3 = origColor
                end)
            end
        end
    end)

    -- Right column
    local rightPanel = Instance.new("Frame")
    rightPanel.BackgroundColor3 = theme.FrameBg
    rightPanel.Position = UDim2.new(0, 196, 0, 30)
    rightPanel.Size = UDim2.new(0, 196, 1, -38)
    rightPanel.Parent = mainFrame
    applyCorner(rightPanel, 2)
    applyBorder(rightPanel, theme.Border)

    local descLabel = Instance.new("TextLabel")
    descLabel.BackgroundTransparency = 1
    descLabel.Position = UDim2.new(0, 6, 0, 6)
    descLabel.Size = UDim2.new(1, -12, 1, -12)
    descLabel.Font = Enum.Font.RobotoMono
    descLabel.Text = description
    descLabel.TextColor3 = theme.SubText
    descLabel.TextSize = 12
    descLabel.TextWrapped = true
    descLabel.Parent = rightPanel

    -- Initial copy button visibility
    local initialData = services[selectedService]
    if initialData and (initialData.CopyLink or initialData.CopyKey) then
        copyBtn.Visible = true
        keyInput.Size = UDim2.new(1, -28, 1, 0)
    end

    local keySys = {}
    function keySys:Destroy()
        keyScreen:Destroy()
    end
    return keySys
end

-- ── Notification System ─────────────────────────────────────────────────────
function RGui:Notify(title, message, duration, options)
    local theme = self._theme
    duration = duration or 3
    options = options or {}

    if not self._notificationGui then
        local gui = Instance.new("ScreenGui")
        gui.Name = "RGui_Notifications"
        gui.ResetOnSpawn = false
        gui.Parent = CoreGui
        self._notificationGui = gui
    end

    local frame = Instance.new("Frame")
    frame.BackgroundColor3 = options.BackgroundColor or theme.NotifyBg
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(0, 220, 0, 60)
    frame.Position = UDim2.new(1, -230, 1, -70)
    frame.Parent = self._notificationGui
    applyCorner(frame, 2)
    applyBorder(frame, theme.Border)

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.RobotoMono
    titleLabel.Text = title or ""
    titleLabel.TextColor3 = options.TitleColor or theme.NotifyTitle
    titleLabel.TextSize = 13
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Position = UDim2.new(0, 8, 0, 4)
    titleLabel.Size = UDim2.new(1, -28, 0, 16)
    titleLabel.Parent = frame

    local msgLabel = Instance.new("TextLabel")
    msgLabel.BackgroundTransparency = 1
    msgLabel.Font = Enum.Font.RobotoMono
    msgLabel.Text = message or ""
    msgLabel.TextColor3 = options.MessageColor or theme.NotifyMsg
    msgLabel.TextSize = 12
    msgLabel.TextWrapped = true
    msgLabel.TextXAlignment = Enum.TextXAlignment.Left
    msgLabel.Position = UDim2.new(0, 8, 0, 22)
    msgLabel.Size = UDim2.new(1, -28, 1, -26)
    msgLabel.Parent = frame

    local closeBtn = Instance.new("TextButton")
    closeBtn.BackgroundTransparency = 1
    closeBtn.Position = UDim2.new(1, -20, 0, 4)
    closeBtn.Size = UDim2.new(0, 16, 0, 16)
    closeBtn.Font = Enum.Font.RobotoMono
    closeBtn.Text = "×"
    closeBtn.TextColor3 = theme.SubText
    closeBtn.TextSize = 14
    closeBtn.Parent = frame
    closeBtn.MouseButton1Click:Connect(function()
        frame:Destroy()
    end)

    task.delay(duration, function()
        if frame and frame.Parent then
            frame:Destroy()
        end
    end)

    -- Stack existing notifications
    local existing = self._notificationGui:GetChildren()
    local offset = 0
    for _, child in ipairs(existing) do
        if child:IsA("Frame") and child ~= frame then
            local newPos = child.Position + UDim2.new(0, 0, 0, -64)
            TweenService:Create(child, TWEEN_FAST, {Position = newPos}):Play()
            offset += 64
        end
    end
    frame.Position = UDim2.new(1, -230, 1, -70 - offset)

    if options.Color then
        local line = Instance.new("Frame")
        line.BackgroundColor3 = options.Color
        line.Size = UDim2.new(0, 3, 1, 0)
        line.BorderSizePixel = 0
        line.Parent = frame
        applyCorner(line, 2)
    end

    return frame
end

-- ── Tab:AddKeybindPicker(text, defaultKey, callback, options) ─────────────────
-- options.Toggle: if true, the picker acts as a toggle hotkey.
--                 callback will be called with (key, newState) on each press.
-- options.DefaultState: initial toggle state (false if omitted)
-- The picker display shows "[ON]" / "[OFF]" when in toggle mode.
                                               
function TabComponent:AddKeybindPicker(text, defaultKey, callback, options)
    local theme = getTheme(self)
    options = options or {}

    local toggleMode = options.Toggle or false
    local currentState = options.DefaultState or false

    local function keyToString(key)
        if type(key) == "string" then return key end
        if typeof(key) == "EnumItem" then return key.Name end
        return "Unbound"
    end

    local currentKeyStr = keyToString(defaultKey or "Unbound")
    local isWaiting = false
    local pressConnection   -- connection for hotkey listener

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 24)
    container.LayoutOrder = self:_nextOrder()
    container.Parent = self._page

    -- Left label
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0, TextService:GetTextSize(text, 13, Enum.Font.RobotoMono, Vector2.new(999, 24)).X + 4, 1, 0)
    label.Font = Enum.Font.RobotoMono
    label.Text = text
    label.TextColor3 = theme.Text
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container

    -- Right side: key display (shows bound key + optional state)
    local keyDisplay = Instance.new("TextLabel")
    keyDisplay.BackgroundColor3 = theme.FrameBg
    keyDisplay.Position = UDim2.new(0, label.Size.X.Offset + 8, 0, 0)
    keyDisplay.Size = UDim2.new(1, -(label.Size.X.Offset + 8 + 48), 1, 0)  -- leave room for Bind button
    keyDisplay.Font = Enum.Font.RobotoMono
    keyDisplay.TextColor3 = currentKeyStr == "Unbound" and theme.SubText or theme.Text
    keyDisplay.TextSize = 13
    keyDisplay.TextXAlignment = Enum.TextXAlignment.Center
    keyDisplay.Parent = container
    applyCorner(keyDisplay, 2)
    applyBorder(keyDisplay, theme.Border)

    -- Bind button
    local bindBtn = Instance.new("TextButton")
    bindBtn.BackgroundColor3 = theme.Accent
    bindBtn.Position = UDim2.new(1, -44, 0, 0)
    bindBtn.Size = UDim2.new(0, 44, 1, 0)
    bindBtn.Font = Enum.Font.RobotoMono
    bindBtn.Text = "Bind"
    bindBtn.TextColor3 = theme.Text
    bindBtn.TextSize = 12
    bindBtn.Parent = container
    applyCorner(bindBtn, 2)
    applyBorder(bindBtn, theme.Border)

    -- Update display text based on current key and toggle state
    local function updateDisplay()
        if currentKeyStr == "Unbound" then
            keyDisplay.Text = "Unbound"
            keyDisplay.TextColor3 = theme.SubText
        else
            if toggleMode then
                keyDisplay.Text = string.format("%s [%s]", currentKeyStr, currentState and "ON" or "OFF")
                keyDisplay.TextColor3 = currentState and theme.Accent or theme.Text
            else
                keyDisplay.Text = currentKeyStr
                keyDisplay.TextColor3 = theme.Text
            end
        end
    end

    updateDisplay()

    -- Disconnect old hotkey listener and connect a new one
    local function reconnectPressListener()
        if pressConnection then
            pressConnection:Disconnect()
            pressConnection = nil
        end
        if currentKeyStr == "Unbound" then return end

        -- Map the string back to detectable types for InputBegan
        local targetKeyCode = nil
        local targetMouse = nil
        for _, name in pairs(Enum.KeyCode:GetEnumItems()) do
            if name.Name == currentKeyStr then
                targetKeyCode = name
                break
            end
        end
        if not targetKeyCode then
            for mouseType, mouseName in pairs({Mouse1 = true, Mouse2 = true, Mouse3 = true, Mouse4 = true, Mouse5 = true}) do
                if currentKeyStr == mouseName then
                    targetMouse = Enum.UserInputType[mouseName]
                    break
                end
            end
        end

        pressConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            local match = false
            if targetKeyCode and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == targetKeyCode then
                match = true
            elseif targetMouse and input.UserInputType == targetMouse then
                match = true
            end
            if match then
                if toggleMode then
                    currentState = not currentState
                    updateDisplay()
                    if callback then callback(currentKeyStr, currentState) end
                else
                    if callback then callback(currentKeyStr) end
                end
            end
        end)
    end

    -- Bind button hover effects
    bindBtn.MouseEnter:Connect(function()
        if not isWaiting then
            bindBtn.BackgroundColor3 = theme.AccentHover
        end
    end)
    bindBtn.MouseLeave:Connect(function()
        if not isWaiting then
            bindBtn.BackgroundColor3 = theme.Accent
        end
    end)

    -- Click Bind to start capturing
    bindBtn.MouseButton1Click:Connect(function()
        if isWaiting then return end
        isWaiting = true
        bindBtn.Text = "..."
        bindBtn.BackgroundColor3 = theme.CheckOn
        keyDisplay.Text = "Press any key..."
        keyDisplay.TextColor3 = theme.Accent

        local con
        con = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            local newKeyStr = nil
            if input.UserInputType == Enum.UserInputType.Keyboard then
                newKeyStr = input.KeyCode.Name
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                newKeyStr = "Mouse1"
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                newKeyStr = "Mouse2"
            elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
                newKeyStr = "Mouse3"
            elseif input.UserInputType == Enum.UserInputType.MouseButton4 then
                newKeyStr = "Mouse4"
            elseif input.UserInputType == Enum.UserInputType.MouseButton5 then
                newKeyStr = "Mouse5"
            end
            if newKeyStr then
                currentKeyStr = newKeyStr
                bindBtn.Text = "Bind"
                bindBtn.BackgroundColor3 = theme.Accent
                isWaiting = false
                con:Disconnect()
                updateDisplay()
                reconnectPressListener()
                -- old-style callback when key is first bound (non-toggle)
                if not toggleMode and callback then
                    callback(currentKeyStr)
                end
            end
        end)
    end)

    -- Initial listener (if default key is already set)
    reconnectPressListener()

    -- Return object
    local pickerObj = {}
    function pickerObj:GetKey()
        return currentKeyStr
    end
    function pickerObj:SetKey(key)
        currentKeyStr = keyToString(key)
        updateDisplay()
        reconnectPressListener()
    end
    function pickerObj:GetState()
        return currentState
    end
    function pickerObj:SetState(state)
        if toggleMode then
            currentState = state
            updateDisplay()
        end
    end

    return pickerObj
end

-- ── Tab:AddCodeEditor(text, placeholder, defaultText, callback) ──────────────
function TabComponent:AddCodeEditor(text, placeholder, defaultText, callback)
    local theme = getTheme(self)
    local currentText = defaultText or ""

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = UDim2.new(1, 0, 0, 120)   -- height enough for several lines
    container.LayoutOrder = self:_nextOrder()
    container.Parent = self._page

    -- Title label
    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, 0, 0, 18)
    titleLabel.Font = Enum.Font.RobotoMono
    titleLabel.Text = text
    titleLabel.TextColor3 = theme.Text
    titleLabel.TextSize = 12
    titleLabel.Parent = container

    -- Scrolling frame for the editor
    local scroll = Instance.new("ScrollingFrame")
    scroll.BackgroundColor3 = theme.FrameBg
    scroll.BorderSizePixel = 0
    scroll.Position = UDim2.new(0, 0, 0, 20)
    scroll.Size = UDim2.new(1, 0, 1, -20)
    scroll.ScrollBarThickness = 4
    scroll.ScrollBarImageColor3 = theme.Accent
    scroll.CanvasSize = UDim2.new(0, 0, 0, 200)  -- larger canvas
    scroll.Parent = container
    applyCorner(scroll, 2)
    applyBorder(scroll, theme.Border)

    -- TextBox filling the scroll
    local box = Instance.new("TextBox")
    box.BackgroundTransparency = 1
    box.Size = UDim2.new(1, -8, 0, 0)  -- height will be auto‑sized later
    box.Position = UDim2.new(0, 4, 0, 4)
    box.Font = Enum.Font.Code           -- monospace
    box.PlaceholderText = placeholder or "Write code..."
    box.PlaceholderColor3 = theme.SubText
    box.Text = currentText
    box.TextColor3 = theme.Text
    box.TextSize = 13
    box.TextXAlignment = Enum.TextXAlignment.Left
    box.TextYAlignment = Enum.TextYAlignment.Top
    box.TextWrapped = false
    box.MultiLine = true
    box.ClearTextOnFocus = false
    box.Parent = scroll

    -- Auto‑resize the TextBox height to its content
    box:GetPropertyChangedSignal("Text"):Connect(function()
        local textSize = TextService:GetTextSize(box.Text, box.TextSize, box.Font, Vector2.new(scroll.AbsoluteSize.X - 16, math.huge))
        box.Size = UDim2.new(1, -8, 0, math.max(textSize.Y + 8, 80))
        scroll.CanvasSize = UDim2.new(0, 0, 0, math.max(textSize.Y + 16, 200))
    end)

    if callback then
        box:GetPropertyChangedSignal("Text"):Connect(function()
            currentText = box.Text
            callback(currentText)
        end)
    end

    return box
end


RGui.Config = {}

function RGui.Config.new(name)
    local self = {}
    self._name = name
    self._data = {}

    -- Internal save helper
    local function saveToStorage(tbl)
        local json = game:GetService("HttpService"):JSONEncode(tbl)
        game:GetService("LocalStorageService"):SetItem("RGui_" .. name, json)
    end

    -- Internal load helper
    local function loadFromStorage()
        local json = game:GetService("LocalStorageService"):GetItem("RGui_" .. name)
        if json then
            local success, decoded = pcall(game.GetService(game, "HttpService").JSONDecode, game:GetService("HttpService"), json)
            if success and type(decoded) == "table" then
                return decoded
            end
        end
        return {}
    end

    function self:Set(key, value)
        self._data[key] = value
    end

    function self:Get(key)
        return self._data[key]
    end

    function self:Save()
        saveToStorage(self._data)
    end

    function self:Load()
        self._data = loadFromStorage()
        return self._data
    end

    -- Convenience: bind a component to a config key
    -- component must have a way to set/get its value (e.g., AddCheckbox returns a row; we can modify callbacks)
    function self:BindCheckbox(tab, key, text, default)
        local cfg = self
        local saved = cfg:Get(key)
        local initial = saved ~= nil and saved or default
        local cb = tab:AddCheckbox(text, initial, function(value)
            cfg:Set(key, value)
        end)
        return cb
    end

    -- Similar bindings for other components can be added as needed.
    return self
end

-- ── Tab:AddImage(imageId, options) ──────────────────────────────────────────
function TabComponent:AddImage(imageId, options)
    local theme = getTheme(self)
    options = options or {}          -- ✅ guard against nil
    -- ✅ accept numbers, string numbers, or full rbxassetid URLs
    if type(imageId) == "number" or tonumber(imageId) then
        imageId = "rbxassetid://" .. tostring(imageId)
    end
    imageId = imageId or ""

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = options.Size or UDim2.new(0, 100, 0, 100)
    container.LayoutOrder = self:_nextOrder()
    container.Parent = self._page
    applyCorner(container, options.CornerRadius or 2)
    if options.Border and options.Border ~= false then
        applyBorder(container, theme.Border)
    end

    local imgLabel = Instance.new("ImageLabel")
    imgLabel.BackgroundTransparency = options.BackgroundTransparency or 1
    imgLabel.Size = UDim2.new(1, 0, 1, 0)
    imgLabel.Image = imageId
    imgLabel.ScaleType = options.ScaleType or Enum.ScaleType.Fit
    imgLabel.Parent = container
    applyCorner(imgLabel, options.CornerRadius or 2)

    local obj = {}
    function obj:SetImage(id)
        if type(id) == "number" or tonumber(id) then
            id = "rbxassetid://" .. tostring(id)
        end
        imgLabel.Image = id
    end
    function obj:GetImage()
        return imgLabel.Image
    end
    function obj:Update(opts)
        opts = opts or {}   -- ✅ guard against nil
        if opts.Size then container.Size = opts.Size end
        if opts.ScaleType then imgLabel.ScaleType = opts.ScaleType end
        if opts.BackgroundTransparency ~= nil then
            imgLabel.BackgroundTransparency = opts.BackgroundTransparency
        end
        if opts.CornerRadius then
            applyCorner(container, opts.CornerRadius)
            applyCorner(imgLabel, opts.CornerRadius)
        end
    end
    function obj:Destroy()
        container:Destroy()
    end
    return obj
end

-- ── Tab:AddViewport(title, options) ─────────────────────────────────────────
function TabComponent:AddViewport(title, options)
    local theme = getTheme(self)
    options = options or {}

    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size = options.Size or UDim2.new(1, 0, 0, 200)
    container.LayoutOrder = self:_nextOrder()
    container.Parent = self._page

    if title and title ~= "" then
        local titleLabel = Instance.new("TextLabel")
        titleLabel.BackgroundTransparency = 1
        titleLabel.Size = UDim2.new(1, 0, 0, 18)
        titleLabel.Font = Enum.Font.RobotoMono
        titleLabel.Text = title
        titleLabel.TextColor3 = theme.Text
        titleLabel.TextSize = 12
        titleLabel.Parent = container
    end

    local viewportFrame = Instance.new("ViewportFrame")
    viewportFrame.BackgroundColor3 = theme.WindowBg
    viewportFrame.BorderSizePixel = 0
    viewportFrame.Position = UDim2.new(0, 0, 0, title and 20 or 0)
    viewportFrame.Size = UDim2.new(1, 0, 1, title and -20 or 0)
    viewportFrame.ImageColor3 = Color3.new(1,1,1)
    viewportFrame.Parent = container
    applyCorner(viewportFrame, 2)
    applyBorder(viewportFrame, theme.Border)

    local camera = Instance.new("Camera")
    camera.FieldOfView = options.FOV or 30
    camera.Parent = viewportFrame
    viewportFrame.CurrentCamera = camera

    -- Model state (we always work with a clone)
    local modelClone = nil
    local modelCenter = Vector3.zero  -- always (0,0,0) because we pivot to origin
    local modelRadius = 5             -- orbit radius

    -- Rotation presets
    local rotationPresets = {
        Front  = 0,
        Back   = math.rad(180),
        Left   = math.rad(90),
        Right  = math.rad(-90),
    }
    local currentAngle = rotationPresets[options.StartingRotation or "Front"] or 0

    -- Orbit the camera around the model's center
    local function updateCamera()
        if not modelClone then return end
        local rotCF = CFrame.Angles(0, currentAngle, 0)
        local tiltCF = CFrame.Angles(math.rad(-15), 0, 0)   -- slight top-down tilt
        local offset = rotCF * Vector3.new(0, 0, modelRadius)
        local pos = modelCenter + offset
        camera.CFrame = CFrame.lookAt(pos, modelCenter) * tiltCF
    end

    -- Auto‑rotation
    local autoRotate = options.AutoRotate or false
    local rotationSpeed = math.rad(options.RotationSpeed or 30)
    local heartbeatConn

    local function startAutoRotate()
        if heartbeatConn then heartbeatConn:Disconnect() end
        if autoRotate and modelClone then
            heartbeatConn = game:GetService("RunService").Heartbeat:Connect(function(dt)
                currentAngle = (currentAngle + rotationSpeed * dt) % (2 * math.pi)
                updateCamera()
            end)
        end
    end

    -- Drag rotation
    local dragEnabled = options.DragEnabled or false
    local dragging = false
    local lastMousePos = Vector2.zero

    local inputBeganConn, inputEndedConn, inputChangedConn   -- for cleanup

    inputBeganConn = viewportFrame.InputBegan:Connect(function(input)
        if dragEnabled and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            dragging = true
            lastMousePos = input.Position
        end
    end)

    inputEndedConn = viewportFrame.InputEnded:Connect(function(input)
        if dragEnabled and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
            dragging = false
        end
    end)

    inputChangedConn = viewportFrame.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - lastMousePos
            lastMousePos = input.Position
            local sensitivity = 0.5
            currentAngle = currentAngle + math.rad(-delta.X * sensitivity)
            updateCamera()
        end
    end)

    -- Load / replace model (clones it, never touches the original)
    local function loadModel(originalModel)
        if modelClone then
            modelClone:Destroy()
            modelClone = nil
        end
        if not originalModel then return end

        -- Clone the model
        local clone = originalModel:Clone()
        -- If original is a character, wait for HumanoidRootPart before cloning (best effort)
        if originalModel:IsA("Model") and originalModel:FindFirstChild("Humanoid") then
            local hrp = originalModel:FindFirstChild("HumanoidRootPart")
            if hrp then
                hrp:GetPropertyChangedSignal("CFrame"):Wait()  -- ensure it's loaded
            end
        end

        -- Pivot the clone to origin
        clone:PivotTo(CFrame.new())

        -- Compute bounding box of the clone at origin
        local bboxCenter, bboxSize = clone:GetBoundingBox()

        -- Fallback
        if not bboxCenter then
            bboxCenter = Vector3.zero
            bboxSize = Vector3.new(5, 5, 5)
        end

        modelCenter = Vector3.zero  -- always origin because we pivoted
        modelRadius = math.max(bboxSize.X, bboxSize.Y, bboxSize.Z) * 1.3  -- suitable multiplier

        -- Parent the clone to the viewport
        clone.Parent = viewportFrame
        modelClone = clone

        updateCamera()
        startAutoRotate()
    end

    -- Load initial model if provided
    if options.Model then
        loadModel(options.Model)
    end

    -- Public API
    local obj = {}
    function obj:SetModel(newModel)
        loadModel(newModel)
    end
    function obj:SetRotation(rotationKey)
        if rotationPresets[rotationKey] then
            currentAngle = rotationPresets[rotationKey]
            updateCamera()
        end
    end
    function obj:SetAutoRotate(enabled)
        autoRotate = enabled
        startAutoRotate()
    end
    function obj:SetSpeed(speed)
        rotationSpeed = math.rad(speed)
        if autoRotate then startAutoRotate() end
    end
    function obj:GetModel()
        return modelClone
    end
    function obj:Destroy()
        if heartbeatConn then heartbeatConn:Disconnect() end
        if inputBeganConn then inputBeganConn:Disconnect() end
        if inputEndedConn then inputEndedConn:Disconnect() end
        if inputChangedConn then inputChangedConn:Disconnect() end
        if modelClone then modelClone:Destroy() end
        container:Destroy()
    end
    return obj
end

-- ── Window:Destroy() ────────────────────────────────────────────────────────
function RGui:Destroy()
    if self._watermark then self._watermark:Destroy() end
    if self._notificationGui then self._notificationGui:Destroy() end
    self._screen:Destroy()
end

return RGui
