--[[
    R-GUI Library vWho ever Knuws – Complete Polished Edition
    Features:
    - Windows: collapsible, draggable, resizable, optional icon
    - Tabs with optional icons
    - Components: Button, Checkbox, Slider, Dropdown, SearchableDropdown,
      MultiSelectDropdown, MultiSelectSearchableDropdown, ColorPicker,
      Label, Section, Separator, TextBox
    - Smooth Catmull‑Rom graph (spline)
    - Watermark (draggable, matches titlebar style, Update() method)
    - Key System (two‑column, service dropdown, copy button, icon)
    - Notification system (stacking toasts)
    - Risky custom colour warning (notifies when a component uses a custom colour)
    - All GUIs parented to CoreGui
    - Fully themeable
]]

local RGui = {}
RGui.__index = RGui

local TabComponent = {}
TabComponent.__index = TabComponent

