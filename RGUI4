            pcall(function() setclipboard(toCopy) end)
            -- Visual feedback
            copyBtn.BackgroundColor3 = theme.Accent
            task.delay(0.3, function()
                copyBtn.BackgroundColor3 = theme.FrameBg
            end)
        end
