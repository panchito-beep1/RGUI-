-- ── Default Theme (classic v1.1 blue) ─────────────────────────────────────────
RGui.DefaultTheme = {
    WindowBg      = Color3.fromRGB(21, 22, 23),
    TitleBg       = Color3.fromRGB(41, 74, 122),
    Border        = Color3.fromRGB(21, 22, 23),
    Text          = Color3.fromRGB(255, 255, 255),
    SubText       = Color3.fromRGB(180, 180, 180),
    Accent        = Color3.fromRGB(56, 101, 165),
    AccentHover   = Color3.fromRGB(56, 101, 165),
    FrameBg       = Color3.fromRGB(41, 74, 122),
    FrameBgHover  = Color3.fromRGB(56, 101, 165),
    CheckOff      = Color3.fromRGB(21, 22, 23),
