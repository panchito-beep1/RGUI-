        isOpen = not isOpen
        local targetHeight = isOpen and (24 + 90) or 24
        TweenService:Create(container, TWEEN_FAST, {Size = UDim2.new(1, 0, 0, targetHeight)}):Play()
    end)

    local function createChannelSlider(channelName, yPos, initialVal, channelUpdater)
        local label = Instance.new("TextLabel")
        label.BackgroundTransparency = 1
        label.Position = UDim2.new(0, 6, 0, yPos)
        label.Size = UDim2.new(0, 14, 0, 20)
        label.Font = Enum.Font.RobotoMono
        label.Text = channelName
        label.TextColor3 = theme.SubText
        label.TextSize = 12
        label.Parent = expandFrame

        local track = Instance.new("Frame")
        track.BackgroundColor3 = theme.SliderTrack
        track.Position = UDim2.new(0, 26, 0, yPos + 7)
        track.Size = UDim2.new(1, -34, 0, 6)
        track.Parent = expandFrame
        applyCorner(track, 2)
        applyBorder(track, theme.Border)

        local fill = Instance.new("Frame")
        fill.BackgroundColor3 = theme.Accent
        fill.Size = UDim2.new(initialVal, 0, 1, 0)
        fill.Parent = track
        applyCorner(fill, 2)

        local handle = Instance.new("TextButton")
        handle.AnchorPoint = Vector2.new(0.5, 0.5)
        handle.Position = UDim2.new(initialVal, 0, 0.5, 0)
        handle.Size = UDim2.new(0, 8, 0, 16)
        handle.BackgroundColor3 = theme.Text
        handle.Text = ""
        handle.Parent = track
        applyCorner(handle, 2)

        local dragging = false
        local function onDrag(input)
            local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            handle.Position = UDim2.new(rel, 0, 0.5, 0)
            fill.Size = UDim2.new(rel, 0, 1, 0)
            channelUpdater(rel)
            preview.BackgroundColor3 = Color3.new(r, g, b)
            if callback then callback(Color3.new(r, g, b)) end
        end

        handle.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
        end)
        UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
        end)
        UserInputService.InputChanged:Connect(function(i)
            if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then onDrag(i) end
        end)
        track.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then onDrag(i) end
        end)
    end

    createChannelSlider("R", 8,  r, function(v) r = v end)
    createChannelSlider("G", 34, g, function(v) g = v end)
    createChannelSlider("B", 60, b, function(v) b = v end)
end

